# 后端配置
PORT=3000
NODE_ENV=development

# 数据库配置 (群晖 NAS MariaDB/MySQL)
DB_HOST=192.168.1.100
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=nocturne_sync

# 安全配置
JWT_SECRET=your_super_secret_key_change_this

# 前端集成配置 (注意：修改此处需重新运行 npm run build 才能生效)
# Android APK 默认会连接到此地址
VITE_API_URL=http://dxtbass.huazo.xyz:4000
